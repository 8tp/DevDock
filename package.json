{
  "name": "devdock",
  "version": "1.0.0",
  "productName": "DevDock",
  "description": "The local development command center — manage projects, ports, services, and logs",
  "main": "./out/main/index.js",
  "author": "DevDock Contributors",
  "license": "MIT",
  "keywords": ["developer-tools", "electron", "port-manager", "local-development", "devtools"],
  "build": {
    "appId": "com.devdock.app",
    "productName": "DevDock",
    "icon": "resources/icon.png",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*.png", "**/*.icns"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "artifactName": "DevDock-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  },
  "scripts": {
    "dev": "npm run rebuild:electron --silent && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "npm run rebuild:node --silent && vitest run",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "lint": "eslint . --ext .ts,.tsx",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "pack": "electron-vite build && electron-builder --dir",
    "rebuild:electron": "file node_modules/better-sqlite3/build/Release/better_sqlite3.node 2>/dev/null | grep -q arm64 && echo 'already arm64' || npx node-gyp rebuild --directory=node_modules/better-sqlite3 --arch=arm64 --target=$(npx electron --version | tr -d v) --dist-url=https://electronjs.org/headers",
    "rebuild:node": "file node_modules/better-sqlite3/build/Release/better_sqlite3.node 2>/dev/null | grep -q x86_64 && echo 'already x86_64' || npm rebuild better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.3.9",
    "geist": "^1.7.0",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.3",
    "@tanstack/react-virtual": "^3.13.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.22.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.9"
  }
}
